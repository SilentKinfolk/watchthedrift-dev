# Node / Vite build
node_modules/
dist/
dist-ssr/
.vite/
*.local
*.log

# Build-loop runner state (scripts/issue-loop.sh)
.loop-logs/
.loop-state
.loop-stop

# Local-only Claude Code settings
.claude/settings.local.json

# Harness scratch + outputs (developer-only, not shipped)
tools/local/
tools/out/

# Augmentation output: derived hard-condition TRAINING variants (issue #7). Never
# committed — they are distortions of (gitignored) source photos; only code +
# trained weights ship. Re-generate with `npm run augment`.
tools/training/

# Fixture images: CC-licensed test photos are NOT redistributed from this repo —
# re-fetch them from the Commons URLs in tools/fixtures/CREDITS.md (the repo stays
# scrupulously CC-only / image-free; only code and trained weights are committed).
tools/fixtures/*.jpg
tools/fixtures/*.jpeg
tools/fixtures/*.png
tools/fixtures/*.webp

# A stray root-level traineddata copy (the shipped one lives in public/traineddata/)
/digits.traineddata

# OS
.DS_Store
